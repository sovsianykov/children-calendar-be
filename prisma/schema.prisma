generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EventCategory {
  school
  sports
  birthday
  doctor
  play
  music
  other
}

model CalendarEvent {
  id          String        @id @default(uuid())
  title       String
  date        String        // "YYYY-MM-DD"
  time        String?       // "HH:MM"
  category    EventCategory
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("calendar_events")
}
